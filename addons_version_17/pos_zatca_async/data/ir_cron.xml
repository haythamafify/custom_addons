<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Cron: Process pending ZATCA EDI documents asynchronously.

            Why noupdate="1"?
            So the admin can tune the interval without it being reset on module upgrade.

            Default: every 5 minutes — adjust based on invoice volume.
            For high-volume restaurants: every 1-2 minutes.
            For low-volume: every 10-15 minutes.
        -->
        <record id="ir_cron_zatca_async" model="ir.cron">
            <field name="name">ZATCA EDI: Process Pending Invoices (Async)</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_zatca_edi()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

    </data>
</odoo>
